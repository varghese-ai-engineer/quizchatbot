# ============================================================
# QuizChatbot — Environment Configuration
# ============================================================
# Copy this file to .env and edit values as needed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env for your machine, then:
#   docker compose up --build -d
#
# All values below have working defaults for local Docker setup.
# Only change what you need to customise.
# ============================================================

# ── Ollama (LLM + Embeddings) ─────────────────────────────────
# Ollama runs on your HOST machine (not inside Docker).
# Default port is 11434. Change only if you run Ollama on a different port.
OLLAMA_HOST=http://host.docker.internal:11434

# LLM model — must be pulled in Ollama first (ollama pull <model>)
# Default: qwen2.5:7b (~4.7 GB RAM)
# Lighter alternatives: qwen2.5:3b, llama3.2:3b, mistral:7b
LLM_MODEL=qwen2.5:7b

# Embedding model — must be pulled in Ollama first
EMBED_MODEL=nomic-embed-text

# ── Application Ports ─────────────────────────────────────────
# Change these if any port is already in use on your machine.
# Only the LEFT (host) port changes — right side is internal.
FRONTEND_PORT=8090      # http://localhost:8090  (PHP app)
API_PORT=8100           # http://localhost:8100  (FastAPI + Swagger)
CHROMA_PORT_HOST=8200   # http://localhost:8200  (ChromaDB)
MYSQL_PORT_HOST=3307    # localhost:3307         (MySQL)

# ── MySQL Database ────────────────────────────────────────────
# These are internal container credentials — change only if you
# want a custom database name or credentials.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=quizchatbot
DB_USER=quizuser
DB_PASS=quizpass

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=knowledge_base

# ── Security ──────────────────────────────────────────────────
# IMPORTANT: Change API_SECRET_KEY before any production deployment!
API_SECRET_KEY=change_this_to_a_strong_secret_key
